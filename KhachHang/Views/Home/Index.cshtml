@model IEnumerable<KhachHang.Models.FieldDto>

@{
    ViewBag.Title = "Sport Plus - Chinh Phục Sân Cỏ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<main>
    <!-- Hero Section - Thu nhỏ lại -->
    <section class="relative h-[380px] md:h-[460px] flex items-center justify-center overflow-hidden">
        <div class="absolute inset-0 z-0 bg-gradient-to-br from-emerald-900 via-emerald-800 to-emerald-950"></div>
        <div class="relative z-10 container mx-auto px-6 text-center text-white">
            <h1 class="font-headline font-extrabold text-5xl md:text-7xl mb-4 tracking-tight leading-none">
                CHINH PHỤC SÂN CỎ
            </h1>
            <p class="font-body text-xl md:text-2xl max-w-2xl mx-auto text-white/90">
                Sport Plus - Cụm sân bóng đá mini chất lượng cao tại Tân Phú
            </p>
        </div>
    </section>

    <!-- Phần giới thiệu - Gọn hơn -->
    <section class="py-16 md:py-20 bg-surface-container-low">
        <div class="max-w-screen-2xl mx-auto px-6 md:px-8">
            <div class="flex flex-col md:flex-row justify-between items-end mb-10 gap-6">
                <div>
                    <span class="text-primary font-bold uppercase tracking-widest text-sm mb-3 block">CỤM SÂN BÓNG MINI TÂN PHÚ</span>
                    <h2 class="font-headline font-extrabold text-4xl md:text-5xl text-on-surface tracking-tight">SPORT PLUS</h2>
                </div>
            </div>

            <div class="max-w-4xl mx-auto bg-white rounded-3xl p-8 md:p-12 shadow-sm">
                <p class="text-lg leading-relaxed text-gray-700 mb-10">
                    <strong>Sân Bóng Đá Sport Plus</strong> là cụm sân bóng đá Mini tại
                    <strong>31/2 Đ. Kênh 19/5, Sơn Kỳ, Tân Phú, Hồ Chí Minh</strong>.
                    Chúng tôi cung cấp dịch vụ cho thuê sân đá banh giao lưu và tổ chức giải đấu.
                </p>

                <h3 class="font-headline font-bold text-3xl mb-8 text-emerald-800">Cụm sân bóng mini Sport Plus có gì?</h3>
                
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-y-5 gap-x-8 mb-12 text-[17px]">
                    <div class="flex items-start gap-4">
                        <span class="material-symbols-outlined text-3xl text-primary">grass</span>
                        <p><strong>Chất lượng cỏ siêu đẹp</strong></p>
                    </div>
                    <div class="flex items-start gap-4">
                        <span class="material-symbols-outlined text-3xl text-primary">wc</span>
                        <p><strong>Khu nhà vệ sinh sạch sẽ</strong></p>
                    </div>
                    <div class="flex items-start gap-4">
                        <span class="material-symbols-outlined text-3xl text-primary">local_parking</span>
                        <p><strong>Bãi đỗ xe rộng rãi</strong></p>
                    </div>
                    <div class="flex items-start gap-4">
                        <span class="material-symbols-outlined text-3xl text-primary">storefront</span>
                        <p><strong>Canteen, nước uống đầy đủ</strong></p>
                    </div>
                    <div class="flex items-start gap-4">
                        <span class="material-symbols-outlined text-3xl text-primary">shopping_bag</span>
                        <p><strong>Cho thuê giày bóng đá, bóng và áo tập...</strong></p>
                    </div>
                </div>

                <div class="bg-emerald-50 border border-emerald-100 rounded-2xl p-8 md:p-10">
                    <h3 class="font-bold text-2xl mb-5 text-emerald-800">Cho Thuê Sân</h3>
                    <p class="text-gray-700 leading-relaxed text-lg">
                        Chúng tôi mở cửa chào đón hàng chục đội bóng từ quận Tân Phú và các khu vực lân cận,
                        mang đến trải nghiệm thi đấu chuyên nghiệp trên sân cỏ chuẩn quốc tế.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section - Gọn và nổi bật -->
    <section class="py-16 md:py-20 bg-emerald-900">
        <div class="max-w-3xl mx-auto px-6 text-center text-white">
            <h2 class="font-headline font-extrabold text-4xl md:text-5xl mb-5 tracking-tight">
                Sẵn sàng ra sân?
            </h2>
            <p class="text-lg md:text-xl mb-10 text-emerald-100/80">
                Trải nghiệm sân bóng mini chất lượng cao tại Tân Phú ngay hôm nay!
            </p>
            <a asp-controller="TaiKhoan" asp-action="DangKy"
                   class="inline-block px-14 py-5 bg-white text-emerald-900 rounded-full font-black text-lg shadow-xl hover:scale-105 transition-all active:scale-95">
                ĐĂNG KÝ NGAY
            </a>
        </div>
    </section>
</main>
