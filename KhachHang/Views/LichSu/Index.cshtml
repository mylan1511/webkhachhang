@model IEnumerable<KhachHang.Models.BookingSummaryDto>

@{
    ViewBag.Title = "Lịch sử đặt sân | Sport Plus";
    Layout = "~/Views/Shared/_Layout.cshtml";

    int? currentStatus = ViewBag.StatusId as int?;
}

<main class="min-h-screen bg-surface py-10 px-4">

    <div class="max-w-7xl mx-auto">

        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-5 mb-10">
            <div>
                <h1 class="text-4xl font-headline font-extrabold text-on-surface">
                    Lịch sử đặt sân
                </h1>

                <p class="text-on-surface-variant mt-2">
                    Theo dõi trạng thái booking và thanh toán của bạn
                </p>
            </div>

            <a asp-controller="Home"
                   asp-action="Index"
                   class="inline-flex items-center gap-2 px-5 py-3 rounded-2xl bg-primary text-white font-bold shadow hover:opacity-90 transition">
                <span class="material-symbols-outlined">sports_soccer</span>
                Đặt sân mới
            </a>
        </div>

        <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-5 mb-8">
            <div class="flex flex-wrap gap-3">

                <a asp-action="Index"
                       class="px-5 py-2 rounded-2xl font-bold transition @(currentStatus == null ? "bg-primary text-white" : "bg-gray-100 text-gray-700 hover:bg-gray-200")">
                    Tất cả
                </a>

                <a asp-action="Index"
                       asp-route-statusId="5"
                       class="px-5 py-2 rounded-2xl font-bold transition @(currentStatus == 5 ? "bg-yellow-500 text-white" : "bg-yellow-100 text-yellow-700 hover:bg-yellow-200")">
                    Chờ đặt cọc
                </a>

                <a asp-action="Index"
                       asp-route-statusId="2"
                       class="px-5 py-2 rounded-2xl font-bold transition @(currentStatus == 2 ? "bg-blue-600 text-white" : "bg-blue-100 text-blue-700 hover:bg-blue-200")">
                    Đã đặt cọc
                </a>

                <a asp-action="Index"
                       asp-route-statusId="4"
                       class="px-5 py-2 rounded-2xl font-bold transition @(currentStatus == 4 ? "bg-emerald-600 text-white" : "bg-emerald-100 text-emerald-700 hover:bg-emerald-200")">
                    Hoàn tất
                </a>

                <a asp-action="Index"
                       asp-route-statusId="6"
                       class="px-5 py-2 rounded-2xl font-bold transition @(currentStatus == 6 ? "bg-red-600 text-white" : "bg-red-100 text-red-700 hover:bg-red-200")">
                    Đã hủy
                </a>
            </div>
        </div>

        @if (!Model.Any())
        {
            <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-14 text-center">
                <div class="w-24 h-24 mx-auto rounded-full bg-gray-100 flex items-center justify-center mb-6">
                    <span class="material-symbols-outlined text-5xl text-gray-400">
                        history
                    </span>
                </div>

                <h2 class="text-3xl font-headline font-extrabold mb-3">
                    Chưa có lịch sử đặt sân
                </h2>

                <p class="text-on-surface-variant mb-8">
                    Bạn chưa thực hiện booking nào trên hệ thống.
                </p>

                <a asp-controller="Home"
                       asp-action="Index"
                       class="inline-flex items-center gap-2 px-6 py-4 rounded-2xl bg-primary text-white font-bold shadow-lg hover:opacity-90 transition">
                    <span class="material-symbols-outlined">add</span>
                    Đặt sân ngay
                </a>
            </div>
        }
        else
        {
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

                @foreach (var booking in Model)
                {
                    string statusLower = (booking.Status ?? "").ToLower();

                    bool forceFullPaid =
                        Context.Session.GetString($"FullPayment_{booking.BookingId}") == "true";

                    bool isWaitingDeposit =
                        booking.StatusId == 1 ||
                        booking.StatusId == 5 ||
                        statusLower.Contains("chờ");

                    bool isCompleted =
                        forceFullPaid ||
                        booking.StatusId == 3 ||
                        booking.StatusId == 4 ||
                        statusLower.Contains("hoàn tất") ||
                        statusLower.Contains("đã thanh toán");

                    bool isDeposited =
                        !isCompleted &&
                        (
                            booking.StatusId == 2 ||
                            statusLower.Contains("đặt cọc") ||
                            statusLower.Contains("đã xác nhận")
                        );

                    bool isCancelled =
                        booking.StatusId == 6 ||
                        statusLower.Contains("hủy") ||
                        statusLower.Contains("quá hạn");

                    string badgeClass =
                        isCancelled
                            ? "bg-red-100 text-red-700"
                            : isCompleted
                                ? "bg-emerald-100 text-emerald-700"
                                : isDeposited
                                    ? "bg-blue-100 text-blue-700"
                                    : "bg-yellow-100 text-yellow-700";

                    <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden">

                        <div class="p-6 border-b border-gray-100">
                            <div class="flex items-start justify-between gap-4">
                                <div>
                                    <h3 class="text-2xl font-headline font-extrabold">
                                        #BK-@booking.BookingId
                                    </h3>

                                    <p class="text-on-surface-variant mt-1">
                                        @(booking.FieldName ?? "Sân bóng")
                                    </p>
                                </div>

                                <span class="px-4 py-2 rounded-full text-sm font-bold @badgeClass">
                                    @(isCompleted
                                        ? "Thanh toán toàn bộ thành công"
                                        : booking.Status ?? "Không xác định")
                                </span>
                            </div>
                        </div>

                        <div class="p-6">

                            <div class="space-y-4 mb-6">
                                <div class="flex justify-between">
                                    <span class="text-on-surface-variant">
                                        Ngày đặt
                                    </span>

                                    <span class="font-semibold">
                                        @(booking.CreatedAt?.ToString("dd/MM/yyyy"))
                                    </span>
                                </div>

                                <div class="flex justify-between">
                                    <span class="text-on-surface-variant">
                                        Tổng tiền
                                    </span>

                                    <span class="font-bold text-primary">
                                        @booking.TotalAmount?.ToString("N0")đ
                                    </span>
                                </div>
                            </div>

                            <div class="flex flex-wrap gap-3">

                                <a asp-controller="DatSan"
                                       asp-action="ChiTietDon"
                                       asp-route-id="@booking.BookingId"
                                       class="flex-1 min-w-[140px] text-center px-5 py-3 rounded-2xl bg-gray-100 hover:bg-gray-200 text-gray-700 font-bold transition">
                                    Chi tiết
                                </a>

                                @if (isWaitingDeposit || isDeposited)
                                {
                                    <a asp-controller="ThanhToan"
                                           asp-action="Index"
                                           asp-route-id="@booking.BookingId"
                                           class="flex-1 min-w-[140px] text-center px-5 py-3 rounded-2xl bg-primary hover:opacity-90 text-white font-bold transition">
                                        @(isDeposited ? "Thanh toán tiếp" : "Thanh toán")
                                    </a>
                                }

                                @if (!isCancelled)
                                {
                                    <form asp-controller="LichSu"
                                          asp-action="HuySan"
                                          method="post"
                                          class="cancel-booking-form flex-1 min-w-[140px]">

                                        @Html.AntiForgeryToken()

                                        <input type="hidden"
                                               name="bookingId"
                                               value="@booking.BookingId" />

                                        <input type="hidden"
                                               name="reason"
                                               value="Khách hàng hủy từ lịch sử đặt sân" />

                                        <input type="hidden"
                                               name="returnToHistory"
                                               value="true" />

                                        <button type="button"
                                                class="btn-open-cancel w-full px-5 py-3 rounded-2xl bg-red-100 hover:bg-red-200 text-red-700 font-bold transition">
                                            Hủy sân
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <!-- CANCEL MODAL -->
    <div id="cancelModal"
         class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 backdrop-blur-sm p-4">

        <div class="w-full max-w-md bg-white rounded-3xl shadow-2xl p-8 text-center">

            <div class="w-20 h-20 mx-auto rounded-full bg-red-100 flex items-center justify-center mb-5">
                <span class="material-symbols-outlined text-red-600 text-5xl">
                    warning
                </span>
            </div>

            <h3 class="text-3xl font-headline font-extrabold mb-3">
                Hủy sân?
            </h3>

            <p class="text-gray-600 leading-7">
                bạn có chắc chắn muốn hủy sân này không ?
            </p>

            <div class="grid grid-cols-2 gap-4 mt-8">
                <button id="btnCancelClose"
                        type="button"
                        class="py-4 rounded-2xl border font-bold hover:bg-gray-50">
                    Quay lại
                </button>

                <button id="btnCancelConfirm"
                        type="button"
                        class="py-4 rounded-2xl bg-red-600 hover:bg-red-700 text-white font-bold">
                    Xác nhận hủy
                </button>
            </div>
        </div>
    </div>

    <script>
            let currentCancelForm = null;

            document.addEventListener("DOMContentLoaded", function () {

                const modal = document.getElementById("cancelModal");
                const closeBtn = document.getElementById("btnCancelClose");
                const confirmBtn = document.getElementById("btnCancelConfirm");

                document.querySelectorAll(".btn-open-cancel").forEach(button => {

                    button.addEventListener("click", function () {

                        currentCancelForm = this.closest("form");

                        modal.classList.remove("hidden");
                        modal.classList.add("flex");
                    });
                });

                closeBtn.addEventListener("click", function () {

                    modal.classList.add("hidden");
                    modal.classList.remove("flex");

                    currentCancelForm = null;
                });

                confirmBtn.addEventListener("click", function () {

                    if (currentCancelForm) {
                        currentCancelForm.submit();
                    }
                });

                modal.addEventListener("click", function (e) {

                    if (e.target === modal) {

                        modal.classList.add("hidden");
                        modal.classList.remove("flex");

                        currentCancelForm = null;
                    }
                });
            });
    </script>
</main>