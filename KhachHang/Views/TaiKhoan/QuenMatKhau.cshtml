@{
    ViewBag.Title = "Quên mật khẩu | Sport Plus";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<main class="min-h-[calc(100vh-80px)] flex items-center justify-center bg-surface p-4 md:p-8">

    <div class="w-full max-w-5xl grid grid-cols-1 md:grid-cols-2 bg-white rounded-3xl overflow-hidden shadow-2xl">

        <!-- LEFT VISUAL -->
        <div class="relative hidden md:flex flex-col justify-end p-10 min-h-[640px] overflow-hidden bg-gradient-to-br from-emerald-900 via-emerald-800 to-emerald-950">

            <!-- Decorative grid -->
            <div class="absolute inset-0"
                 style="background-image: linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px); background-size: 36px 36px;"></div>

            <!-- Decorative circle -->
            <div class="absolute top-16 right-10 w-56 h-56 rounded-full border border-white/10"></div>
            <div class="absolute top-24 right-18 w-36 h-36 rounded-full border border-white/10"></div>
            <div class="absolute -bottom-10 -left-10 w-64 h-64 rounded-full bg-white/5"></div>

            <!-- Icon lớn -->
            <div class="absolute top-12 left-10 w-16 h-16 rounded-2xl bg-white/10 flex items-center justify-center">
                <span class="material-symbols-outlined text-white text-4xl">shield_lock</span>
            </div>

            <div class="absolute inset-0 bg-gradient-to-t from-emerald-950/60 to-transparent"></div>

            <div class="relative z-10 text-white">
                <div class="inline-flex items-center gap-2 bg-white/15 backdrop-blur-md px-4 py-2 rounded-full text-xs font-bold uppercase tracking-widest mb-5">
                    <span class="material-symbols-outlined text-base">shield_lock</span>
                    Khôi phục bảo mật
                </div>

                <h1 class="text-5xl font-headline font-extrabold leading-tight mb-4">
                    LẤY LẠI<br />TÀI KHOẢN
                </h1>

                <p class="text-white/85 text-lg">
                    Nhập email đã đăng ký để nhận mã OTP và đặt lại mật khẩu.
                </p>
            </div>
        </div>

        <!-- RIGHT FORM -->
        <div class="p-8 md:p-12 flex flex-col justify-center">

            <!-- STEP INDICATOR -->
            <div class="flex items-center mb-10">
                <div class="step active" id="step1Indicator">1</div>
                <div class="line"></div>
                <div class="step" id="step2Indicator">2</div>
                <div class="line"></div>
                <div class="step" id="step3Indicator">3</div>
            </div>

            <!-- MESSAGE -->
            <div id="messageBox" class="hidden mb-5 rounded-2xl px-4 py-3 text-sm font-medium"></div>

            <!-- STEP 1 -->
            <section id="step1" class="space-y-6">
                <div>
                    <span class="text-[10px] font-bold uppercase tracking-widest text-primary">
                        Bước 1
                    </span>

                    <h2 class="text-3xl font-headline font-extrabold text-on-surface mt-2">
                        Quên mật khẩu
                    </h2>

                    <p class="text-on-surface-variant mt-2">
                        Nhập email của bạn để nhận mã OTP xác thực.
                    </p>
                </div>

                <div>
                    <label class="block text-[10px] font-bold uppercase tracking-widest text-on-surface-variant mb-2">
                        Email
                    </label>

                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant">
                            mail
                        </span>

                        <input id="email"
                               type="email"
                               class="w-full bg-surface-container border-0 rounded-full py-4 pl-12 pr-4 focus:ring-2 focus:ring-primary focus:bg-white outline-none transition-all"
                               placeholder="vuphong623@gmail.com" />
                    </div>
                </div>

                <button id="sendOtpBtn"
                        type="button"
                        onclick="sendOtp()"
                        class="w-full bg-primary text-on-primary font-headline font-extrabold py-4 rounded-full uppercase tracking-wide shadow-lg hover:scale-[1.02] active:scale-95 transition-all">
                    Gửi OTP
                </button>
            </section>

            <!-- STEP 2 -->
            <section id="step2" class="hidden space-y-6">
                <div>
                    <span class="text-[10px] font-bold uppercase tracking-widest text-primary">
                        Bước 2
                    </span>

                    <h2 class="text-3xl font-headline font-extrabold text-on-surface mt-2">
                        Xác thực OTP
                    </h2>

                    <p class="text-on-surface-variant mt-2">
                        Nhập mã OTP đã được gửi đến email của bạn.
                    </p>
                </div>

                <div>
                    <label class="block text-[10px] font-bold uppercase tracking-widest text-on-surface-variant mb-2">
                        Mã OTP
                    </label>

                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant">
                            pin
                        </span>

                        <input id="otp"
                               maxlength="6"
                               class="w-full bg-surface-container border-0 rounded-full py-4 pl-12 pr-4 text-center tracking-[0.4em] font-bold text-lg focus:ring-2 focus:ring-primary focus:bg-white outline-none transition-all"
                               placeholder="------" />
                    </div>
                </div>

                <button id="verifyOtpBtn"
                        type="button"
                        onclick="verifyOtp()"
                        class="w-full bg-primary text-on-primary font-headline font-extrabold py-4 rounded-full uppercase tracking-wide shadow-lg hover:scale-[1.02] active:scale-95 transition-all">
                    Xác nhận OTP
                </button>

                <button type="button"
                        onclick="goStep(1)"
                        class="w-full text-primary font-bold hover:underline">
                    Quay lại nhập email
                </button>
            </section>

            <!-- STEP 3 -->
            <section id="step3" class="hidden space-y-6">
                <div>
                    <span class="text-[10px] font-bold uppercase tracking-widest text-primary">
                        Bước 3
                    </span>

                    <h2 class="text-3xl font-headline font-extrabold text-on-surface mt-2">
                        Đặt lại mật khẩu
                    </h2>

                    <p class="text-on-surface-variant mt-2">
                        Tạo mật khẩu mới cho tài khoản của bạn.
                    </p>
                </div>

                <div>
                    <label class="block text-[10px] font-bold uppercase tracking-widest text-on-surface-variant mb-2">
                        Mật khẩu mới
                    </label>

                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant">lock</span>
                        <input id="newPassword"
                               type="password"
                               class="w-full bg-surface-container border-0 rounded-full py-4 pl-12 pr-12 focus:ring-2 focus:ring-primary focus:bg-white outline-none transition-all"
                               placeholder="Nhập mật khẩu mới" />
                        <button type="button"
                                onclick="togglePw('newPassword', 'iconNew')"
                                class="absolute right-4 top-1/2 -translate-y-1/2 text-on-surface-variant hover:text-primary transition-colors">
                            <span id="iconNew" class="material-symbols-outlined">visibility_off</span>
                        </button>
                    </div>
                </div>

                <div>
                    <label class="block text-[10px] font-bold uppercase tracking-widest text-on-surface-variant mb-2">
                        Xác nhận mật khẩu
                    </label>

                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant">lock</span>
                        <input id="confirmPassword"
                               type="password"
                               class="w-full bg-surface-container border-0 rounded-full py-4 pl-12 pr-12 focus:ring-2 focus:ring-primary focus:bg-white outline-none transition-all"
                               placeholder="Nhập lại mật khẩu" />
                        <button type="button"
                                onclick="togglePw('confirmPassword', 'iconConfirm')"
                                class="absolute right-4 top-1/2 -translate-y-1/2 text-on-surface-variant hover:text-primary transition-colors">
                            <span id="iconConfirm" class="material-symbols-outlined">visibility_off</span>
                        </button>
                    </div>
                </div>

                <button id="resetPasswordBtn"
                        type="button"
                        onclick="resetPassword()"
                        class="w-full bg-primary text-on-primary font-headline font-extrabold py-4 rounded-full uppercase tracking-wide shadow-lg hover:scale-[1.02] active:scale-95 transition-all">
                    Đổi mật khẩu
                </button>
            </section>

            <div class="mt-8 text-center">
                <a asp-action="DangNhap"
                       class="text-on-surface-variant hover:text-primary font-medium transition-all">
                    Quay lại đăng nhập
                </a>
            </div>
        </div>
    </div>
</main>

<style>
    .step {
        width: 42px;
        height: 42px;
        border-radius: 999px;
        background: var(--step-bg, #e5e7eb);
        color: #6b7280;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        transition: all .25s ease;
    }

        .step.active {
            background: rgb(var(--color-primary, 22 101 52));
            color: white;
            box-shadow: 0 10px 25px rgba(0,0,0,.15);
            transform: scale(1.08);
        }

    .line {
        flex: 1;
        height: 3px;
        background: #e5e7eb;
        margin: 0 12px;
        border-radius: 999px;
    }

        .line.active {
            background: rgb(var(--color-primary, 22 101 52));
        }
</style>

<script>
    let emailGlobal = "";
    let resetToken = "";

    function showMessage(message, type = "error") {
        const box = document.getElementById("messageBox");

        box.classList.remove("hidden");
        box.textContent = message;

        box.className =
            "mb-5 rounded-2xl px-4 py-3 text-sm font-medium " +
            (type === "success"
                ? "bg-green-50 text-green-700"
                : "bg-red-50 text-red-700");
    }

    function clearMessage() {
        const box = document.getElementById("messageBox");
        box.classList.add("hidden");
        box.textContent = "";
    }

    async function sendOtp() {
        clearMessage();

        emailGlobal = document.getElementById("email").value.trim();

        if (!emailGlobal) {
            showMessage("Vui lòng nhập email.");
            return;
        }

        const btn = document.getElementById("sendOtpBtn");
        btn.disabled = true;
        btn.textContent = "Đang gửi...";

        const res = await fetch("/TaiKhoan/QuenMatKhauSendOtp", {
            method: "POST",
            headers: {
                "Content-Type": "application/json"
            },
            body: JSON.stringify({
                email: emailGlobal
            })
        });

        const text = await res.text();

        btn.disabled = false;
        btn.textContent = "Gửi OTP";

        if (!res.ok) {
            showMessage("Gửi OTP thất bại: " + text);
            return;
        }

        showMessage("Đã gửi OTP đến email của bạn.", "success");
        goStep(2);
    }

    async function verifyOtp() {
        clearMessage();

        const otp = document.getElementById("otp").value.trim();

        if (!otp) {
            showMessage("Vui lòng nhập mã OTP.");
            return;
        }

        const btn = document.getElementById("verifyOtpBtn");
        btn.disabled = true;
        btn.textContent = "Đang xác thực...";

        const res = await fetch("/TaiKhoan/VerifyOtpAjax", {
            method: "POST",
            headers: {
                "Content-Type": "application/json"
            },
            body: JSON.stringify({
                email: emailGlobal,
                otp
            })
        });

        const text = await res.text();

        btn.disabled = false;
        btn.textContent = "Xác nhận OTP";

        if (!res.ok) {
            showMessage("OTP không đúng: " + text);
            return;
        }

        const data = JSON.parse(text);

        resetToken =
            data?.data?.resetToken ||
            data?.data?.ResetToken ||
            data?.resetToken ||
            "";

        if (!resetToken) {
            showMessage("Không lấy được reset token.");
            return;
        }

        showMessage("Xác thực OTP thành công.", "success");
        goStep(3);
    }

    async function resetPassword() {
        clearMessage();

        const newPassword = document.getElementById("newPassword").value;
        const confirmPassword = document.getElementById("confirmPassword").value;

        if (!newPassword || !confirmPassword) {
            showMessage("Vui lòng nhập đầy đủ mật khẩu.");
            return;
        }

        if (newPassword !== confirmPassword) {
            showMessage("Mật khẩu xác nhận không khớp.");
            return;
        }

        const btn = document.getElementById("resetPasswordBtn");
        btn.disabled = true;
        btn.textContent = "Đang đổi...";

        const res = await fetch("/TaiKhoan/ResetPasswordAjax", {
            method: "POST",
            headers: {
                "Content-Type": "application/json"
            },
            body: JSON.stringify({
                resetToken,
                newPassword,
                confirmPassword
            })
        });

        const text = await res.text();

        btn.disabled = false;
        btn.textContent = "Đổi mật khẩu";

        if (!res.ok) {
            showMessage("Đổi mật khẩu thất bại: " + text);
            return;
        }

        showMessage("Đổi mật khẩu thành công. Đang chuyển về đăng nhập...", "success");

        setTimeout(() => {
            window.location.href = "/TaiKhoan/DangNhap";
        }, 1200);
    }

    function togglePw(inputId, iconId) {
        const input = document.getElementById(inputId);
        const icon = document.getElementById(iconId);
        if (input.type === "password") {
            input.type = "text";
            icon.textContent = "visibility";
        } else {
            input.type = "password";
            icon.textContent = "visibility_off";
        }
    }

    function goStep(step) {
        // Ẩn tất cả step content
        [1,2,3].forEach(i => {
            document.getElementById("step" + i).classList.add("hidden");
            const ind = document.getElementById("step" + i + "Indicator");
            ind.classList.remove("active");
        });

        // Active các step đã qua + step hiện tại
        for (let i = 1; i <= step; i++) {
            document.getElementById("step" + i + "Indicator").classList.add("active");
        }

        // Active các line đã qua
        const lines = document.querySelectorAll(".line");
        lines.forEach((line, idx) => {
            if (idx < step - 1) {
                line.classList.add("active");
            } else {
                line.classList.remove("active");
            }
        });

        // Hiện step hiện tại
        document.getElementById("step" + step).classList.remove("hidden");
        clearMessage();
    }
</script>