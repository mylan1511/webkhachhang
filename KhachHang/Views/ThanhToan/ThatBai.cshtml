@{
    ViewBag.Title = "Thanh toán thất bại";
    Layout = "~/Views/Shared/_Layout.cshtml";

    int bookingId = ViewBag.BookingId ?? 0;
}

<div class="min-h-screen bg-surface py-16 px-4">
    <div class="max-w-2xl mx-auto">

        <div class="bg-white rounded-3xl shadow-xl p-10 text-center">

            <div class="w-24 h-24 mx-auto mb-6 rounded-full bg-red-100 flex items-center justify-center">
                <span class="material-symbols-outlined text-5xl text-red-600">
                    error
                </span>
            </div>

            <h1 class="text-4xl font-headline font-extrabold text-red-600 mb-3">
                Thanh toán thất bại
            </h1>

            <p class="text-on-surface-variant text-lg leading-relaxed mb-8">
                Giao dịch VNPay chưa được hoàn tất hoặc đã bị hủy.
            </p>

            <div class="bg-red-50 border-2 border-red-200 rounded-2xl px-8 py-5 mb-8 inline-block w-full">
                <p class="text-xs font-bold uppercase tracking-widest text-red-600 mb-1">
                    Mã đơn
                </p>

                <p class="text-4xl font-headline font-extrabold text-red-700">
                    #BK-@bookingId
                </p>
            </div>

            <div class="p-4 bg-yellow-50 text-yellow-700 rounded-2xl text-sm text-left leading-relaxed mb-8">
                <strong>Lưu ý:</strong>
                Đơn đặt sân của bạn chưa được thanh toán thành công. Bạn có thể thử thanh toán lại hoặc quay về chi tiết đơn để kiểm tra trạng thái.
            </div>

            <div class="flex flex-col sm:flex-row gap-4 justify-center">

                <a asp-controller="ThanhToan"
                       asp-action="Index"
                       asp-route-id="@bookingId"
                       class="px-6 py-3 bg-primary hover:bg-emerald-700 text-white rounded-2xl font-bold transition">
                    Thanh toán lại
                </a>

                <a asp-controller="DatSan"
                       asp-action="ChiTietDon"
                       asp-route-id="@bookingId"
                       class="px-6 py-3 border border-gray-300 hover:bg-gray-50 rounded-2xl font-bold transition">
                    Xem chi tiết đơn
                </a>

                <a asp-controller="LichSu"
                       asp-action="Index"
                       class="px-6 py-3 border border-gray-300 hover:bg-gray-50 rounded-2xl font-bold transition">
                    Lịch sử đặt sân
                </a>

            </div>
        </div>
    </div>
</div>