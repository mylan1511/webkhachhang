@model KhachHang.Models.BookingDto

@{
    ViewBag.Title = "Chi tiết đơn đặt sân | Sport Plus";
    Layout = "~/Views/Shared/_Layout.cshtml";

    string statusLower = (Model.Status ?? "").ToLower();

    bool forceFullPaid =
        Context.Session.GetString($"FullPayment_{Model.BookingId}") == "true";

    bool isCancelled =
        Model.StatusId == 6 ||
        statusLower.Contains("hủy");

    bool isWaitingDeposit =
        !forceFullPaid &&
        (
            Model.StatusId == 1 ||
            Model.StatusId == 5 ||
            statusLower.Contains("chờ đặt cọc") ||
            statusLower.Contains("chờ thanh toán")
        );

    bool isDeposited =
        !forceFullPaid &&
        (
            Model.StatusId == 2 ||
            statusLower.Contains("đã đặt cọc")
        );

    bool isPaidFull =
        forceFullPaid ||
        Model.StatusId == 3 ||
        Model.StatusId == 4 ||
        statusLower.Contains("đã thanh toán") ||
        statusLower.Contains("hoàn tất");

    string statusText =
        forceFullPaid
            ? "Thanh toán toàn bộ thành công"
            : Model.Status ?? "Không xác định";

    string statusClass = isCancelled
        ? "bg-red-100 text-red-700"
        : isPaidFull
            ? "bg-emerald-100 text-emerald-700"
            : isDeposited
                ? "bg-blue-100 text-blue-700"
                : isWaitingDeposit
                    ? "bg-yellow-100 text-yellow-700"
                    : "bg-gray-100 text-gray-700";

    string noteMessage =
      isCancelled
          ? "Đơn đặt sân đã bị hủy."
          : isPaidFull
              ? "Đơn đã được thanh toán toàn bộ. Nếu hủy sân, hệ thống sẽ giữ lại tiền cọc theo chính sách."
              : isDeposited
                  ? "Đơn đã được đặt cọc thành công. Nếu hủy sân, tiền cọc sẽ không được hoàn lại theo chính sách hệ thống."
                  : isWaitingDeposit
                      ? "Bạn cần thanh toán tiền cọc bằng VNPay để xác nhận đơn đặt sân."
                      : "Trạng thái đơn chưa xác định.";

    KhachHang.Models.BookingDetailDto? firstSlot = null;

    if (Model.Details != null)
    {
        foreach (var item in Model.Details)
        {
            firstSlot = item;
            break;
        }
    }

    DateTime? matchTime = null;
    DateTime? cancelDeadline = null;

    if (firstSlot != null)
    {
        matchTime = firstSlot.SlotDate.ToDateTime(firstSlot.StartTime);
        cancelDeadline = matchTime.Value.AddHours(-2);
    }

    bool canCancel =
        cancelDeadline.HasValue &&
        DateTime.Now <= cancelDeadline.Value &&
        !isCancelled;

    decimal serviceTotal =
        Model.Services?.Sum(x => x.Total) ?? 0m;

    decimal totalAmount =
        Model.TotalAmount ?? 0m;

    decimal depositAmount =
        forceFullPaid
            ? totalAmount
            : Model.DepositAmount ?? 0m;

    decimal paidAmount =
        forceFullPaid
            ? totalAmount
            : Model.Deposit?.PaidAmount ?? 0m;

    decimal remainingAmount =
        forceFullPaid
            ? 0m
            : totalAmount - depositAmount;

    string cancelMessage = canCancel
        ? "Bạn vẫn còn trong thời gian được hủy đơn theo chính sách."
        : "Đã quá thời gian hủy hoặc đơn không còn được phép hủy.";
}

<main class="min-h-screen bg-surface py-10 px-4">

    <div class="max-w-screen-2xl mx-auto">

        <div class="mb-8">
            <div class="flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-outline">

                <a href="/" class="hover:text-primary">
                    Trang chủ
                </a>

                <span class="material-symbols-outlined text-sm">
                    chevron_right
                </span>

                <a asp-controller="LichSu"
                       asp-action="Index"
                       class="hover:text-primary">
                    Lịch sử
                </a>

                <span class="material-symbols-outlined text-sm">
                    chevron_right
                </span>

                <span class="text-primary">
                    Chi tiết đơn
                </span>
            </div>
        </div>

        <section class="relative overflow-hidden rounded-3xl bg-gradient-to-r from-primary to-emerald-500 text-white p-8 md:p-10 shadow-xl mb-8">

            <div class="absolute right-[-80px] top-[-80px] w-72 h-72 rounded-full bg-white/10"></div>
            <div class="absolute right-[120px] bottom-[-100px] w-52 h-52 rounded-full bg-white/10"></div>

            <div class="relative z-10 flex flex-col lg:flex-row lg:items-center lg:justify-between gap-8">

                <div>
                    <span class="inline-flex items-center gap-2 bg-white/15 px-4 py-2 rounded-full text-xs font-bold uppercase tracking-widest mb-5">
                        <span class="material-symbols-outlined text-base">
                            receipt_long
                        </span>
                        Phiếu đặt sân
                    </span>

                    <h1 class="text-4xl md:text-5xl font-headline font-extrabold tracking-tight">
                        #BK-@Model.BookingId
                    </h1>

                    <p class="mt-3 text-white/80">
                        @(firstSlot?.FieldName ?? "Đơn đặt sân Sport Plus")
                    </p>
                </div>

                <div class="lg:text-right">

                    <p class="text-white/70 text-sm mb-2">
                        Ngày tạo đơn
                    </p>

                    <p class="font-bold text-lg mb-4">
                        @(Model.CreatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "Không rõ")
                    </p>

                    <span class="inline-flex px-5 py-2 rounded-full font-bold @statusClass">
                        @statusText
                    </span>
                </div>
            </div>
        </section>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">

            <div class="lg:col-span-8 space-y-8">

                @if (Model.Customer != null)
                {
                    <section class="bg-white rounded-3xl p-8 shadow-sm border border-gray-100">
                        <div class="flex items-center gap-4 mb-6">
                            <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center">
                                <span class="material-symbols-outlined text-primary text-3xl">
                                    person
                                </span>
                            </div>

                            <div>
                                <p class="text-[10px] font-bold uppercase tracking-widest text-primary">
                                    Khách hàng
                                </p>

                                <h2 class="text-2xl font-headline font-extrabold">
                                    Thông tin khách hàng
                                </h2>
                            </div>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
                            <div class="bg-surface-container-lowest rounded-2xl p-5">
                                <p class="text-sm text-on-surface-variant mb-1">
                                    Họ tên
                                </p>

                                <p class="font-bold">
                                    @Model.Customer.FullName
                                </p>
                            </div>

                            <div class="bg-surface-container-lowest rounded-2xl p-5">
                                <p class="text-sm text-on-surface-variant mb-1">
                                    Email
                                </p>

                                <p class="font-bold break-all">
                                    @Model.Customer.Email
                                </p>
                            </div>

                            <div class="bg-surface-container-lowest rounded-2xl p-5">
                                <p class="text-sm text-on-surface-variant mb-1">
                                    Số điện thoại
                                </p>

                                <p class="font-bold">
                                    @Model.Customer.Phone
                                </p>
                            </div>
                        </div>
                    </section>
                }

                <section class="bg-white rounded-3xl p-8 shadow-sm border border-gray-100">

                    <div class="flex items-center gap-4 mb-8">
                        <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center">
                            <span class="material-symbols-outlined text-primary text-3xl">
                                event_available
                            </span>
                        </div>

                        <div>
                            <p class="text-[10px] font-bold uppercase tracking-widest text-primary">
                                Lịch sân
                            </p>

                            <h2 class="text-2xl font-headline font-extrabold">
                                Khung giờ đã đặt
                            </h2>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">

                        @if (Model.Details != null)
                        {
                            @foreach (var item in Model.Details)
                            {
                                <div class="rounded-3xl border border-gray-100 bg-surface-container-lowest p-6 hover:shadow-md transition-all">

                                    <div class="flex justify-between gap-4">

                                        <div>
                                            <h3 class="font-bold text-xl">
                                                @item.FieldName
                                            </h3>

                                            <p class="text-sm text-on-surface-variant mt-1">
                                                @item.FieldType
                                            </p>

                                            <div class="mt-4 space-y-2 text-sm text-on-surface-variant">

                                                <p class="flex items-center gap-2">
                                                    <span class="material-symbols-outlined text-primary text-base">
                                                        calendar_month
                                                    </span>
                                                    @item.SlotDate.ToString("dd/MM/yyyy")
                                                </p>

                                                <p class="flex items-center gap-2">
                                                    <span class="material-symbols-outlined text-primary text-base">
                                                        schedule
                                                    </span>
                                                    @item.StartTime.ToString(@"HH\:mm")
                                                    -
                                                    @item.EndTime.ToString(@"HH\:mm")
                                                </p>
                                            </div>
                                        </div>

                                        <div class="text-right">
                                            <p class="text-xs text-on-surface-variant">
                                                Thành tiền
                                            </p>

                                            <p class="text-2xl font-headline font-extrabold text-primary mt-1">
                                                @item.Price.ToString("N0")đ
                                            </p>
                                        </div>
                                    </div>

                                    @if (!isCancelled && canCancel && (isDeposited || isPaidFull))
                                    {
                                        <div class="mt-4 pt-4 border-t border-gray-100">
                                            <a asp-controller="DatSan"
                                                   asp-action="DoiLich"
                                                   asp-route-bookingId="@Model.BookingId"
                                                   asp-route-bookingDetailId="@item.BookingDetailId"
                                                   class="mt-4 inline-flex items-center gap-2 px-4 py-3 rounded-2xl bg-primary text-white font-bold hover:bg-emerald-700 transition-all shadow-md">

                                                <span class="material-symbols-outlined text-base">
                                                    event_repeat
                                                </span>

                                                Đổi lịch khung giờ này
                                            </a>
                                        </div>
                                    }
                                </div>
                            }
                        }

                    </div>
                </section>

                <section class="bg-white rounded-3xl p-8 shadow-sm border border-gray-100">

                    <div class="flex items-center gap-4 mb-8">
                        <div class="w-14 h-14 rounded-2xl bg-orange-50 flex items-center justify-center">
                            <span class="material-symbols-outlined text-orange-600 text-3xl">
                                local_cafe
                            </span>
                        </div>

                        <div>
                            <p class="text-[10px] font-bold uppercase tracking-widest text-primary">
                                Dịch vụ
                            </p>

                            <h2 class="text-2xl font-headline font-extrabold">
                                Dịch vụ đi kèm
                            </h2>
                        </div>
                    </div>

                    @if (Model.Services != null && Model.Services.Any())
                    {
                        <div class="space-y-4">
                            @foreach (var service in Model.Services)
                            {
                                <div class="flex justify-between items-center rounded-3xl bg-surface-container-lowest border border-gray-100 p-5">

                                    <div>
                                        <h3 class="font-bold text-lg">
                                            @service.ServiceName
                                        </h3>

                                        <p class="text-sm text-on-surface-variant mt-1">
                                            Số lượng: @service.Quantity
                                        </p>

                                        <p class="text-sm text-on-surface-variant">
                                            Đơn giá: @service.UnitPrice.ToString("N0")đ
                                        </p>
                                    </div>

                                    <div class="text-right">
                                        <p class="text-xs text-on-surface-variant">
                                            Thành tiền
                                        </p>

                                        <p class="text-xl font-headline font-extrabold text-primary">
                                            @service.Total.ToString("N0")đ
                                        </p>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-on-surface-variant bg-surface-container-lowest rounded-3xl p-8">
                            Không có dịch vụ đi kèm.
                        </div>
                    }
                </section>

                <section class="bg-blue-50 rounded-3xl p-6 text-blue-700 border border-blue-100">

                    <h3 class="font-bold text-lg mb-3">
                        Thông báo
                    </h3>

                    <p>
                        @noteMessage
                    </p>

                    <div class="mt-4 text-sm leading-7">
                        <strong>Quy định hủy:</strong>
                        Chỉ được hủy trước giờ thi đấu 2 tiếng.

                        <br />

                        Hạn hủy:

                        <strong>
                            @(cancelDeadline.HasValue
                                ? cancelDeadline.Value.ToString("dd/MM/yyyy HH:mm")
                                : "Không xác định")
                        </strong>

                        <br />

                        <strong>
                            @cancelMessage
                        </strong>
                    </div>
                </section>
            </div>

            <aside class="lg:col-span-4">

                <div class="sticky top-24 space-y-6">

                    <section class="bg-white rounded-3xl p-8 shadow-xl border border-gray-100">

                        <h3 class="font-headline font-extrabold text-2xl mb-6">
                            Thanh toán
                        </h3>

                        <div class="space-y-5">

                            <div class="flex justify-between">
                                <span class="text-on-surface-variant">
                                    Tạm tính
                                </span>

                                <span class="font-bold">
                                    @((Model.SubTotal ?? 0m).ToString("N0"))đ
                                </span>
                            </div>

                            @if (serviceTotal > 0)
                            {
                                <div class="flex justify-between">
                                    <span class="text-on-surface-variant">
                                        Tiền dịch vụ
                                    </span>

                                    <span class="font-bold text-orange-600">
                                        @serviceTotal.ToString("N0")đ
                                    </span>
                                </div>
                            }

                            <div class="flex justify-between">
                                <span class="text-on-surface-variant">
                                    Giảm giá
                                </span>

                                <span class="font-bold text-red-500">
                                    -@((Model.DiscountAmount ?? 0m).ToString("N0"))đ
                                </span>
                            </div>

                            <div class="flex justify-between">
                                <span class="text-on-surface-variant">
                                    Thuế
                                </span>

                                <span class="font-bold">
                                    @((Model.TaxAmount ?? 0m).ToString("N0"))đ
                                </span>
                            </div>

                            <hr />

                            <div class="flex justify-between text-2xl font-headline font-extrabold">
                                <span>
                                    TỔNG
                                </span>

                                <span class="text-primary">
                                    @totalAmount.ToString("N0")đ
                                </span>
                            </div>

                            <div class="flex justify-between">
                                <span class="text-on-surface-variant">
                                    @(forceFullPaid ? "Đã thanh toán toàn bộ" : "Tiền cọc")
                                </span>

                                <span class="font-bold text-emerald-600">
                                    @depositAmount.ToString("N0")đ
                                </span>
                            </div>

                            @if (isDeposited || isPaidFull)
                            {
                                <div class="flex justify-between">
                                    <span class="text-on-surface-variant">
                                        Còn lại
                                    </span>

                                    <span class="font-bold text-red-600">
                                        @remainingAmount.ToString("N0")đ
                                    </span>
                                </div>
                            }
                        </div>

                        @if (Model.Deposit != null)
                        {
                            <div class="mt-6 bg-surface-container-lowest rounded-2xl p-5">

                                <div class="flex justify-between mb-3">
                                    <span class="text-on-surface-variant">
                                        Trạng thái cọc
                                    </span>

                                    <span class="font-bold text-primary">
                                        @(forceFullPaid
                                            ? "Đã thanh toán toàn bộ"
                                            : Model.Deposit.Status)
                                    </span>
                                </div>

                                <div class="flex justify-between mb-3">
                                    <span class="text-on-surface-variant">
                                        Cần thanh toán
                                    </span>

                                    <span class="font-bold">
                                        @(forceFullPaid
                                            ? totalAmount.ToString("N0")
                                            : (Model.Deposit.RequiredAmount ?? 0m).ToString("N0"))đ
                                    </span>
                                </div>

                                <div class="flex justify-between">
                                    <span class="text-on-surface-variant">
                                        Đã thanh toán
                                    </span>

                                    <span class="font-bold">
                                        @paidAmount.ToString("N0")đ
                                    </span>
                                </div>

                                @if (Model.Deposit.DeadlineAt.HasValue && !forceFullPaid)
                                {
                                    <div class="mt-3 text-sm text-red-500">
                                        Hạn thanh toán:
                                        <strong>
                                            @Model.Deposit.DeadlineAt.Value.ToString("dd/MM/yyyy HH:mm")
                                        </strong>
                                    </div>
                                }
                            </div>
                        }

                        @if (isCancelled)
                        {
                            <div class="mt-8 p-5 rounded-2xl bg-red-50 text-red-700 font-bold text-center">
                                Đơn đặt sân này đã được hủy.
                            </div>

                            <a asp-controller="LichSu"
                                   asp-action="Index"
                                   class="block mt-4 w-full text-center py-4 border rounded-2xl font-bold hover:bg-gray-50 transition-all">
                                QUAY LẠI LỊCH SỬ
                            </a>
                        }
                        else
                        {
                            <div class="mt-8 space-y-4">

                                @if (isWaitingDeposit)
                                {
                                    <a asp-controller="ThanhToan"
                                           asp-action="Index"
                                           asp-route-id="@Model.BookingId"
                                           class="block w-full text-center py-4 bg-blue-700 text-white rounded-2xl font-bold hover:bg-blue-800 transition-all">
                                        THANH TOÁN CỌC BẰNG VNPAY
                                    </a>
                                }

                                @if (isDeposited)
                                {
                                    <a asp-controller="ThanhToan"
                                           asp-action="Index"
                                           asp-route-id="@Model.BookingId"
                                           class="block w-full text-center py-4 bg-blue-700 text-white rounded-2xl font-bold hover:bg-blue-800 transition-all">
                                        THANH TOÁN PHẦN CÒN LẠI BẰNG VNPAY
                                    </a>

                                    <div class="p-4 rounded-2xl bg-emerald-50 text-emerald-700 text-sm font-medium">
                                        Bạn cũng có thể thanh toán phần còn lại bằng tiền mặt khi đến sân.
                                    </div>
                                }

                                @if (isPaidFull)
                                {
                                    <div class="p-5 rounded-2xl bg-emerald-50 text-emerald-700 font-bold text-center">
                                        Đơn đặt sân đã được thanh toán toàn bộ.
                                    </div>
                                }

                                @if (canCancel)
                                {
                                    <form asp-controller="DatSan"
                                          asp-action="HuySan"
                                          method="post">

                                        <input type="hidden"
                                               name="bookingId"
                                               value="@Model.BookingId" />

                                        <input type="hidden"
                                               name="reason"
                                               value="Khách hủy sân - mất tiền cọc theo chính sách" />

                                        <button type="submit"
                                                class="w-full py-4 bg-red-600 hover:bg-red-700 text-white rounded-2xl font-bold transition-all">
                                            HỦY ĐẶT SÂN
                                        </button>
                                    </form>

                                    @if (forceFullPaid || isDeposited)
                                    {
                                        <div class="p-4 rounded-2xl bg-red-50 text-red-700 text-sm font-medium">
                                            Khi hủy sân, tiền cọc sẽ không được hoàn lại theo chính sách hệ thống.
                                        </div>
                                    }
                                }

                                <a asp-controller="LichSu"
                                       asp-action="Index"
                                       class="block w-full text-center py-4 border rounded-2xl font-bold hover:bg-gray-50 transition-all">
                                    QUAY LẠI LỊCH SỬ
                                </a>
                            </div>
                        }
                    </section>

                    <section class="bg-primary text-white rounded-3xl p-8 shadow-lg">

                        <h3 class="font-headline font-extrabold text-xl mb-5">
                            Thông tin đơn
                        </h3>

                        <div class="space-y-4 text-sm">

                            <div class="flex justify-between">
                                <span>
                                    Trạng thái
                                </span>

                                <span class="font-bold">
                                    @statusText
                                </span>
                            </div>

                            <div class="flex justify-between">
                                <span>
                                    Số lần đổi lịch
                                </span>

                                <span class="font-bold">
                                    @Model.RescheduleCount
                                </span>
                            </div>

                            <div class="flex justify-between">
                                <span>
                                    Mã giảm giá
                                </span>

                                <span class="font-bold">
                                    @(Model.PromotionCode ?? "Không có")
                                </span>
                            </div>

                            <div class="flex justify-between">
                                <span>
                                    Ngày cập nhật
                                </span>

                                <span class="font-bold">
                                    @(Model.UpdatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "Không rõ")
                                </span>
                            </div>
                        </div>
                    </section>
                </div>
            </aside>
        </div>
    </div>
</main>